# Copia este archivo a .env y ajusta los valores.

# Entorno: development | production | test
NODE_ENV=development

# Puerto del servidor HTTP
PORT=4000

# Driver de base de datos: sqlite (dev local) | postgres (prod)
DB_DRIVER=sqlite

# Para sqlite: ruta al archivo. Para postgres: URL de conexión completa.
DATABASE_URL=local.db

# Cero Retención de Datos en logs: si es true, los logs NUNCA incluyen
# el contenido de las respuestas del ciudadano (solo metadatos).
ZDR_LOGS=true

# --- Acceso del gestor (panel de administración) ---
# Cuenta única para administrar expedientes. CÁMBIALA en producción.
GESTOR_USUARIO=gestor
GESTOR_PASSWORD=cambia-esta-clave
# Secreto para firmar las sesiones (JWT). Usa una cadena larga y aleatoria.
JWT_SECRET=dev-secreto-cambia-esto-por-favor-1234
