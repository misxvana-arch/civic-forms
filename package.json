{
  "name": "civic-forms",
  "version": "0.1.0",
  "description": "Plataforma de formularios cívicos con base de datos propia (alternativa seria a Google Forms)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env --max-old-space-size=250 --import tsx src/infrastructure/http/server.ts",
    "build": "tsc --noEmit",
    "start": "node --env-file-if-exists=.env --max-old-space-size=250 --import tsx src/infrastructure/http/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^10.1.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "postgres": "^3.4.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
